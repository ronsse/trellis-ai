# Trellis credential template — committed for reference.
# Copy to .env (gitignored) and fill in real values.
#
# Two ways to load:
#
# (1) Plain values (legacy, fine for non-sensitive configs):
#     bash:        set -a && source .env && set +a
#     powershell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2] } }
#
# (2) 1Password secret references (preferred for credentials):
#     Set the value to op://<Vault>/<Item>/<Field> in .env, then run with:
#       op run --env-file=.env -- <command>
#     Examples in this template marked with "(op-ref OK)" support this form.
#     Requires 1Password CLI + desktop-app integration toggled on in
#     1Password → Settings → Developer → "Integrate with 1Password CLI".
#
# Once loaded, run the suites that depend on each backend.

# ---------------------------------------------------------------------------
# Neo4j — graph + vector backend live tests
# ---------------------------------------------------------------------------
# Self-hosted via Docker:
#   docker run --rm -d -p 7687:7687 -p 7474:7474 -e NEO4J_AUTH=neo4j/<pw> neo4j:5
#   TRELLIS_TEST_NEO4J_URI=bolt://localhost:7687
#   TRELLIS_TEST_NEO4J_USER=neo4j
#   TRELLIS_TEST_NEO4J_PASSWORD=<pw>
#   TRELLIS_TEST_NEO4J_DATABASE=neo4j
#
# AuraDB Free / Aura Pro:
#   TRELLIS_TEST_NEO4J_URI=neo4j+s://<instance_id>.databases.neo4j.io
#   TRELLIS_TEST_NEO4J_USER=<instance_id>          # AuraDB convention: user = instance_id
#   TRELLIS_TEST_NEO4J_PASSWORD=<from console at instance creation>
#   TRELLIS_TEST_NEO4J_DATABASE=<instance_id>      # AuraDB hosts user data here, not "neo4j"
#
# Run: pytest tests/unit/stores/test_neo4j_*.py tests/unit/stores/contracts/test_neo4j_graph_contract.py

TRELLIS_TEST_NEO4J_URI=
TRELLIS_TEST_NEO4J_USER=neo4j
TRELLIS_TEST_NEO4J_PASSWORD=
TRELLIS_TEST_NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Postgres — graph + document + event_log + pgvector live tests
# ---------------------------------------------------------------------------
# Local Docker:
#   docker run --rm -d -p 5432:5432 -e POSTGRES_PASSWORD=<pw> ankane/pgvector
#   TRELLIS_TEST_PG_DSN=postgresql://postgres:<pw>@localhost:5432/postgres
#
# Run: pytest tests/unit/stores/test_postgres_stores.py
#      tests/unit/stores/test_pgvector.py
#      tests/unit/stores/contracts/test_postgres_graph_contract.py
#      tests/unit/stores/contracts/test_pgvector_contract.py

TRELLIS_TEST_PG_DSN=

# ---------------------------------------------------------------------------
# Production env vars — set when deploying or running `trellis serve` against
# real cloud infra, NOT for tests. Documented here so the .env file becomes
# the single place credentials live during local development.
# ---------------------------------------------------------------------------

# Knowledge plane (graph / vector / document / blob) Postgres DSN
# Per docs/design/adr-planes-and-substrates.md
TRELLIS_KNOWLEDGE_PG_DSN=

# Operational plane (trace / event_log) Postgres DSN
TRELLIS_OPERATIONAL_PG_DSN=

# S3 bucket for blob backend
TRELLIS_S3_BUCKET=

# ---------------------------------------------------------------------------
# LLM provider keys (only needed if running EnrichmentService or LLM-tier
# extractors). All support op-ref form (preferred for shared dev machines).
# Per docs/design/plan-real-corpus-eval.md §5.1.
# ---------------------------------------------------------------------------

# Moonshot AI / Kimi — Phase A primary chat + embedding provider.
# OpenAI-compatible API surface; reuse OpenAIClient with base_url override.
# (op-ref OK) — example: MOONSHOT_API_KEY=op://Agent Secrets/Moonshot-API-Key/credential
MOONSHOT_API_KEY=

# OpenAI — embeddings fallback if Moonshot's embedding endpoint is unavailable
# on the international (.ai) endpoint. Also viable as a chat-provider option.
# (op-ref OK)
OPENAI_API_KEY=

# Anthropic — kept for completeness; not used by the Phase A plan.
# (op-ref OK)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# REST API authentication (trellis-api / `trellis serve`)
# ---------------------------------------------------------------------------
# TRELLIS_AUTH_MODE controls how /api/v1 routes authenticate:
#   off      — every request passes with all scopes (local dev / CI only).
#   optional — requests WITHOUT a credential pass with all scopes
#              (migration mode); requests WITH a credential must present
#              a valid one or get 401.
#   required — every request must present a valid credential.
# Backwards compat when UNSET: behaves as "required" if TRELLIS_API_KEY is
# set, else "off" (the pre-scopes behavior). Any other value refuses to
# start — no silent fallback.
# Scoped keys are minted with `trellis admin api-keys create` and presented
# as `X-API-Key: trellis_ak_...` or `Authorization: Bearer trellis_ak_...`.
TRELLIS_AUTH_MODE=

# Legacy shared secret. A token exactly matching this value is granted ALL
# scopes (admin included) for backwards compatibility. Prefer scoped keys.
# (op-ref OK)
TRELLIS_API_KEY=
