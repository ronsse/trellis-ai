# Trellis credential template — committed for reference.
# Copy to .env (gitignored) and fill in real values.
#
# Loading the file:
#   bash:        set -a && source .env && set +a
#   powershell:  Get-Content .env | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2] } }
#
# Once loaded, run the suites that depend on each backend.

# ---------------------------------------------------------------------------
# Neo4j — graph + vector backend live tests
# ---------------------------------------------------------------------------
# Self-hosted via Docker:
#   docker run --rm -d -p 7687:7687 -p 7474:7474 -e NEO4J_AUTH=neo4j/<pw> neo4j:5
#   TRELLIS_TEST_NEO4J_URI=bolt://localhost:7687
#   TRELLIS_TEST_NEO4J_USER=neo4j
#   TRELLIS_TEST_NEO4J_PASSWORD=<pw>
#   TRELLIS_TEST_NEO4J_DATABASE=neo4j
#
# AuraDB Free / Aura Pro:
#   TRELLIS_TEST_NEO4J_URI=neo4j+s://<instance_id>.databases.neo4j.io
#   TRELLIS_TEST_NEO4J_USER=<instance_id>          # AuraDB convention: user = instance_id
#   TRELLIS_TEST_NEO4J_PASSWORD=<from console at instance creation>
#   TRELLIS_TEST_NEO4J_DATABASE=<instance_id>      # AuraDB hosts user data here, not "neo4j"
#
# Run: pytest tests/unit/stores/test_neo4j_*.py tests/unit/stores/contracts/test_neo4j_graph_contract.py

TRELLIS_TEST_NEO4J_URI=
TRELLIS_TEST_NEO4J_USER=neo4j
TRELLIS_TEST_NEO4J_PASSWORD=
TRELLIS_TEST_NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Postgres — graph + document + event_log + pgvector live tests
# ---------------------------------------------------------------------------
# Local Docker:
#   docker run --rm -d -p 5432:5432 -e POSTGRES_PASSWORD=<pw> ankane/pgvector
#   TRELLIS_TEST_PG_DSN=postgresql://postgres:<pw>@localhost:5432/postgres
#
# Run: pytest tests/unit/stores/test_postgres_stores.py
#      tests/unit/stores/test_pgvector.py
#      tests/unit/stores/contracts/test_postgres_graph_contract.py
#      tests/unit/stores/contracts/test_pgvector_contract.py

TRELLIS_TEST_PG_DSN=

# ---------------------------------------------------------------------------
# Production env vars — set when deploying or running `trellis serve` against
# real cloud infra, NOT for tests. Documented here so the .env file becomes
# the single place credentials live during local development.
# ---------------------------------------------------------------------------

# Knowledge plane (graph / vector / document / blob) Postgres DSN
# Per docs/design/adr-planes-and-substrates.md
TRELLIS_KNOWLEDGE_PG_DSN=

# Operational plane (trace / event_log) Postgres DSN
TRELLIS_OPERATIONAL_PG_DSN=

# S3 bucket for blob backend
TRELLIS_S3_BUCKET=

# LLM provider keys (only needed if running EnrichmentService or LLM-tier extractors)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
